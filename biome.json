{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": { 
    "actions": { 
      "source": { 
        "organizeImports": "on" 
        }
      }
    },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
